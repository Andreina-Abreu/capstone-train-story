## Stop 1 — The Networks

Before comparing numbers, it helps to see what we're actually comparing. The BMT is a web: eight lines branching across Brooklyn, Manhattan, and Queens, sharing tracks, splitting at junctions, and serving dozens of distinct neighborhoods. The Yamanote is a loop: one line, 29 stations, running clockwise and counterclockwise around central Tokyo without a beginning or an end.

That structural difference matters. A loop has no terminal bottlenecks, no branching complexity, and no direction — a delay anywhere propagates around the whole circuit equally. The BMT's branching structure creates flexibility but also fragility: a problem on one trunk can cascade across multiple lines.

::: {.callout-tip appearance="minimal" icon="false"}
-   **Scale:** The BMT spans roughly 80 miles of track across three boroughs. The Yamanote covers just 21 miles — but within that loop sits some of the most valuable urban land on earth, and 26 of its 29 stations rank among JR East's 100 busiest.
-   **Structure:** BMT = branching network, shared trunks, multiple termini. Yamanote = closed loop, single service, no branches.
:::

## MTA Brooklyn-Manhattan Transit (BMT) Map

```{r bmt_leaflet_static_map}
library(readr)
library(leaflet)
library(sf)

gtfs_dir <- "data/mta"

routes     <- read_csv(file.path(gtfs_dir, "routes.txt"), show_col_types = FALSE)
trips      <- read_csv(file.path(gtfs_dir, "trips.txt"), show_col_types = FALSE)
shapes     <- read_csv(file.path(gtfs_dir, "shapes.txt"), show_col_types = FALSE)
stops      <- read_csv(file.path(gtfs_dir, "stops.txt"), show_col_types = FALSE)
stop_times <- read_csv(file.path(gtfs_dir, "stop_times.txt"), show_col_types = FALSE)

bmt_short <- c("J","Z","L","M","N","Q","R","W")

route_hex <- c(
  J="#996633", Z="#996633",
  L="#A7A9AC",
  M="#FF6319",
  N="#FCCC0A", Q="#FCCC0A", R="#FCCC0A", W="#FCCC0A"
)

bmt_routes <- routes %>%
  filter(route_short_name %in% bmt_short) %>%
  select(route_id, route_short_name)

shape_choice <- trips %>%
  inner_join(bmt_routes, by = "route_id") %>%
  filter(!is.na(shape_id)) %>%
  count(route_short_name, shape_id, name = "n_trips") %>%
  group_by(route_short_name) %>%
  slice_max(n_trips, n = 1, with_ties = FALSE) %>%
  ungroup() %>%
  select(route_short_name, shape_id)

bmt_shapes <- shapes %>%
  inner_join(shape_choice, by = "shape_id") %>%
  arrange(route_short_name, shape_id, shape_pt_sequence)

route_trips <- trips %>%
  inner_join(bmt_routes, by = "route_id") %>%
  select(trip_id, route_short_name)

bmt_route_stops <- stop_times %>%
  inner_join(route_trips, by = "trip_id") %>%
  distinct(route_short_name, stop_id) %>%
  inner_join(stops %>% select(stop_id, stop_name, stop_lat, stop_lon), by = "stop_id") %>%
  filter(!is.na(stop_lat), !is.na(stop_lon))

THRESH_M <- 80

route_lines_sf <- bmt_shapes %>%
  st_as_sf(coords = c("shape_pt_lon", "shape_pt_lat"), crs = 4326, remove = FALSE) %>%
  st_transform(3857) %>%
  group_by(route_short_name, shape_id) %>%
  summarise(geometry = st_cast(st_combine(geometry), "LINESTRING"), .groups = "drop") %>%
  group_by(route_short_name) %>%
  summarise(geometry = st_union(geometry), .groups = "drop")

route_lines_tbl <- tibble(
  route_short_name = route_lines_sf$route_short_name,
  route_geom = st_geometry(route_lines_sf)  # sfc list-column (NOT sf)
)

stops_flagged <- bmt_route_stops %>%
  st_as_sf(coords = c("stop_lon", "stop_lat"), crs = 4326, remove = FALSE) %>%
  st_transform(3857) %>%
  left_join(route_lines_tbl, by = "route_short_name") %>%
  mutate(
    dist_m = as.numeric(st_distance(st_geometry(.), route_geom, by_element = TRUE)),
    tooltip = if_else(!is.na(dist_m) & dist_m > THRESH_M,
                      paste0(stop_name, " (limited/alternate service)"),
                      stop_name)
  ) %>%
  st_drop_geometry()

init_lon  <- mean(range(bmt_shapes$shape_pt_lon, na.rm = TRUE))
init_lat  <- mean(range(bmt_shapes$shape_pt_lat, na.rm = TRUE))
init_zoom <- 11

m <- leaflet(options = leafletOptions(
  zoomControl = FALSE,
  dragging = FALSE,
  scrollWheelZoom = FALSE,
  doubleClickZoom = FALSE,
  touchZoom = FALSE,
  boxZoom = FALSE,
  keyboard = FALSE
)) %>%
  addProviderTiles(providers$CartoDB.Positron) %>%
  setView(lng = init_lon, lat = init_lat, zoom = init_zoom)

for (r in bmt_short) {
  m <- m %>%
    addPolylines(
      data = filter(bmt_shapes, route_short_name == r),
      lng = ~shape_pt_lon, lat = ~shape_pt_lat,
      group = r,
      color = route_hex[[r]],
      weight = 5, opacity = 0.9
    ) %>%
    addCircleMarkers(
      data = filter(stops_flagged, route_short_name == r),
      lng = ~stop_lon, lat = ~stop_lat,
      group = r,
      radius = 3.5,
      stroke = TRUE, color = "white", weight = 1,
      fillColor = route_hex[[r]], fillOpacity = 0.95,
      label = ~tooltip
    )
}

m %>%
  addLayersControl(
    overlayGroups = bmt_short,
    options = layersControlOptions(collapsed = FALSE)
  )

