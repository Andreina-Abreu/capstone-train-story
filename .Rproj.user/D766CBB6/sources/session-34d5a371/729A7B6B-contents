## Stop 1 — The Networks

Before any numbers, it helps to understand what kind of thing each system 
actually is, because they are solving the same problem with completely 
different structures, and that structural difference shapes every comparison 
that follows.

The BMT is a web. Eight lines branch across Brooklyn, Manhattan, and Queens, 
sharing trunks, splitting at junctions, serving dozens of distinct 
neighborhoods across roughly 80 miles of track. The Yamanote is a loop: one 
line, 29 stations, 21 miles, running clockwise and counterclockwise around 
Tokyo's commercial and cultural core without a beginning or an end.

That is not a small design distinction. A loop has no terminal bottlenecks 
and no directional asymmetry. When demand moves clockwise, the 
counterclockwise service does not run empty. A delay anywhere on the 
Yamanote propagates around the circuit, but there is no single failure point 
that can cascade across multiple branches simultaneously. The BMT's branching 
structure gives it reach and flexibility that a loop never could, but also a 
fragility: one problem on a shared trunk affects every line running through it.

The maps below make the contrast visible. Look at the BMT and you see a 
system built to reach everywhere. Look at the Yamanote and you see a system 
built to run perfectly.



## MTA Brooklyn-Manhattan Transit (BMT) Map

```{r bmt_leaflet_static_map}
library(readr)
library(leaflet)
library(sf)

gtfs_dir <- "data/mta"

routes     <- read_csv(file.path(gtfs_dir, "routes.txt"), show_col_types = FALSE)
trips      <- read_csv(file.path(gtfs_dir, "trips.txt"), show_col_types = FALSE)
shapes     <- read_csv(file.path(gtfs_dir, "shapes.txt"), show_col_types = FALSE)
stops      <- read_csv(file.path(gtfs_dir, "stops.txt"), show_col_types = FALSE)
stop_times <- read_csv(file.path(gtfs_dir, "stop_times.txt"), show_col_types = FALSE)

bmt_short <- c("J","Z","L","M","N","Q","R","W")

route_hex <- c(
  J="#996633", Z="#996633",
  L="#A7A9AC",
  M="#FF6319",
  N="#FCCC0A", Q="#FCCC0A", R="#FCCC0A", W="#FCCC0A"
)

bmt_routes <- routes %>%
  filter(route_short_name %in% bmt_short) %>%
  select(route_id, route_short_name)

shape_choice <- trips %>%
  inner_join(bmt_routes, by = "route_id") %>%
  filter(!is.na(shape_id)) %>%
  count(route_short_name, shape_id, name = "n_trips") %>%
  group_by(route_short_name) %>%
  slice_max(n_trips, n = 1, with_ties = FALSE) %>%
  ungroup() %>%
  select(route_short_name, shape_id)

bmt_shapes <- shapes %>%
  inner_join(shape_choice, by = "shape_id") %>%
  arrange(route_short_name, shape_id, shape_pt_sequence)

route_trips <- trips %>%
  inner_join(bmt_routes, by = "route_id") %>%
  select(trip_id, route_short_name)

bmt_route_stops <- stop_times %>%
  inner_join(route_trips, by = "trip_id") %>%
  distinct(route_short_name, stop_id) %>%
  inner_join(stops %>% select(stop_id, stop_name, stop_lat, stop_lon), by = "stop_id") %>%
  filter(!is.na(stop_lat), !is.na(stop_lon))

THRESH_M <- 80

route_lines_sf <- bmt_shapes %>%
  st_as_sf(coords = c("shape_pt_lon", "shape_pt_lat"), crs = 4326, remove = FALSE) %>%
  st_transform(3857) %>%
  group_by(route_short_name, shape_id) %>%
  summarise(geometry = st_cast(st_combine(geometry), "LINESTRING"), .groups = "drop") %>%
  group_by(route_short_name) %>%
  summarise(geometry = st_union(geometry), .groups = "drop")

route_lines_tbl <- tibble(
  route_short_name = route_lines_sf$route_short_name,
  route_geom = st_geometry(route_lines_sf)  # sfc list-column (NOT sf)
)

stops_flagged <- bmt_route_stops %>%
  st_as_sf(coords = c("stop_lon", "stop_lat"), crs = 4326, remove = FALSE) %>%
  st_transform(3857) %>%
  left_join(route_lines_tbl, by = "route_short_name") %>%
  mutate(
    dist_m = as.numeric(st_distance(st_geometry(.), route_geom, by_element = TRUE)),
    tooltip = if_else(!is.na(dist_m) & dist_m > THRESH_M,
                      paste0(stop_name, " (limited/alternate service)"),
                      stop_name)
  ) %>%
  st_drop_geometry()

init_lon  <- mean(range(bmt_shapes$shape_pt_lon, na.rm = TRUE))
init_lat  <- mean(range(bmt_shapes$shape_pt_lat, na.rm = TRUE))
init_zoom <- 11

m <- leaflet(options = leafletOptions(
  zoomControl = FALSE,
  dragging = FALSE,
  scrollWheelZoom = FALSE,
  doubleClickZoom = FALSE,
  touchZoom = FALSE,
  boxZoom = FALSE,
  keyboard = FALSE
)) %>%
  addProviderTiles(providers$CartoDB.Positron) %>%
  setView(lng = init_lon, lat = init_lat, zoom = init_zoom)

for (r in bmt_short) {
  m <- m %>%
    addPolylines(
      data = filter(bmt_shapes, route_short_name == r),
      lng = ~shape_pt_lon, lat = ~shape_pt_lat,
      group = r,
      color = route_hex[[r]],
      weight = 5, opacity = 0.9
    ) %>%
    addCircleMarkers(
      data = filter(stops_flagged, route_short_name == r),
      lng = ~stop_lon, lat = ~stop_lat,
      group = r,
      radius = 3.5,
      stroke = TRUE, color = "white", weight = 1,
      fillColor = route_hex[[r]], fillOpacity = 0.95,
      label = ~tooltip
    )
}

m %>%
  addLayersControl(
    overlayGroups = bmt_short,
    options = layersControlOptions(collapsed = FALSE)
  )

```
*The BMT network across three boroughs. Eight lines, shared infrastructure, 
and the operational complexity that comes with a century of incremental 
expansion. Toggle individual lines to isolate shared trunk segments.*


## JR East Yamanote Line Map

```{r yamanote_leaflet}
library(readr)
library(leaflet)

gtfs_path <- "data/jreast"
LIME <- "#32CD32"

routes     <- read_csv(file.path(gtfs_path, "routes.txt"), show_col_types = FALSE)
trips      <- read_csv(file.path(gtfs_path, "trips.txt"), show_col_types = FALSE)
stop_times <- read_csv(file.path(gtfs_path, "stop_times.txt"), show_col_types = FALSE)
stops      <- read_csv(file.path(gtfs_path, "stops.txt"), show_col_types = FALSE)

station_info <- fromJSON(file.path(gtfs_path, "jre_station_info.json"), flatten = TRUE)

station_name_map <- station_info %>%
  transmute(
    stop_name_ja = `odpt:stationTitle.ja`,
    stop_name_en = `odpt:stationTitle.en`
  ) %>%
  filter(!is.na(stop_name_ja), !is.na(stop_name_en)) %>%
  distinct(stop_name_ja, .keep_all = TRUE)

stops <- stops %>%
  left_join(station_name_map, by = c("stop_name" = "stop_name_ja")) %>%
  mutate(stop_name_display = coalesce(stop_name_en, stop_name))

route_desc_safe <- if ("route_desc" %in% names(routes)) routes$route_desc else ""
y_routes <- routes %>%
  mutate(search_text = str_to_lower(paste(route_short_name, route_long_name, route_desc_safe))) %>%
  filter(str_detect(search_text, "yamanote|山手|\\bjy\\b"))

stopifnot(nrow(y_routes) > 0)

y_trips <- trips %>% semi_join(y_routes, by = "route_id")

y_trip <- y_trips %>%
  distinct(trip_id) %>%
  inner_join(stop_times %>% count(trip_id, name = "n_stops"), by = "trip_id") %>%
  arrange(desc(n_stops)) %>%
  slice(1) %>%
  pull(trip_id)

stopifnot(length(y_trip) == 1)

y_path <- stop_times %>%
  filter(trip_id == y_trip) %>%
  arrange(stop_sequence) %>%
  left_join(stops %>% select(stop_id, stop_lat, stop_lon, stop_name_display), by = "stop_id") %>%
  filter(!is.na(stop_lat), !is.na(stop_lon)) %>%
  distinct(stop_id, .keep_all = TRUE)

y_path_closed <- bind_rows(y_path, y_path[1, ])

center_lon <- mean(range(y_path$stop_lon, na.rm = TRUE))
center_lat <- mean(range(y_path$stop_lat, na.rm = TRUE))

leaflet(
  y_path_closed,
  options = leafletOptions(
    zoomControl = FALSE,
    dragging = FALSE,
    scrollWheelZoom = FALSE,
    doubleClickZoom = FALSE,
    touchZoom = FALSE,
    boxZoom = FALSE,
    keyboard = FALSE
  )
) %>%
  addProviderTiles(providers$CartoDB.Positron) %>%
  setView(lng = center_lon, lat = center_lat, zoom = 12) %>%
  addPolylines(
    lng = ~stop_lon, lat = ~stop_lat,
    color = LIME, weight = 5, opacity = 0.9
  ) %>%
  addCircleMarkers(
    lng = ~stop_lon, lat = ~stop_lat,
    radius = 6,
    stroke = TRUE, color = "white", weight = 2,
    fillColor = LIME, fillOpacity = 0.95,
    label = ~stop_name_display
  )
```

*The Yamanote loop around central Tokyo. 26 of its 29 stations rank among 
JR East's 100 busiest. The closed loop means every station benefits equally 
from the same service pattern. There is no branch that gets less.*

