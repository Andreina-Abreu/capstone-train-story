library(tidyverse)
library(plotly)
library(scales)
library(jsonlite)
library(stringr)
df <- readr::read_csv("data/mta/bmt_hour_profile.csv", show_col_types = FALSE)
file.exists("data/mta/mta_hourly.csv")
file.exists(out_file)
# Verify
file.exists(out_file)
library(tidyverse)
library(lubridate)
library(stringr)
# Confirm input exists
stopifnot(file.exists("data/mta/mta_hourly.csv"))
# Read needed columns
hourly <- readr::read_csv(
"data/mta/mta_hourly.csv",
col_select = c(transit_timestamp, transit_mode, station_complex, ridership),
show_col_types = FALSE
)
# BMT route matcher
bmt_routes <- c("J","Z","L","M","N","Q","R","W")
bmt_pat <- paste0("(^|\\s)(", paste(bmt_routes, collapse = "|"), ")(\\s|$)")
# Filter to BMT-served station complexes + parse time
hourly_bmt <- hourly %>%
filter(transit_mode == "subway") %>%
mutate(
routes_txt = str_match(station_complex, "\\(([^)]*)\\)")[,2],
routes_txt = coalesce(routes_txt, ""),
is_bmt_complex = str_detect(routes_txt, bmt_pat),
transit_timestamp_clean = str_trim(str_remove(transit_timestamp, "\\s*\\+.*$")),
ts = mdy_hms(transit_timestamp_clean, tz = "America/New_York", quiet = TRUE),
date = as.Date(ts),
hour = hour(ts),
day_type = if_else(wday(ts) %in% c(1, 7), "Weekend", "Weekday")
) %>%
filter(is_bmt_complex, !is.na(ts), !is.na(hour))
# Aggregate to day-hour then profile
daily_hour_bmt <- hourly_bmt %>%
group_by(date, day_type, hour) %>%
summarise(riders = sum(ridership, na.rm = TRUE), .groups = "drop")
bmt_hour_profile <- daily_hour_bmt %>%
group_by(day_type, hour) %>%
summarise(
avg_riders = mean(riders, na.rm = TRUE),
p10 = quantile(riders, 0.10, na.rm = TRUE),
p90 = quantile(riders, 0.90, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(day_type, hour)
# Write file
out_file <- "data/mta/bmt_hour_profile.csv"
dir.create(dirname(out_file), recursive = TRUE, showWarnings = FALSE)
readr::write_csv(bmt_hour_profile, out_file)
# Verify
file.exists(out_file)
knitr::opts_chunk$set(echo = FALSE, message = FALSE, warning = FALSE)
library(tidyverse)
library(plotly)
library(scales)
library(jsonlite)
library(stringr)
df <- readr::read_csv("data/mta/bmt_hour_profile.csv", show_col_types = FALSE)
mta_blue   <- "#0039A6"
mta_orange <- "#FF6319"
fmtN <- function(v) scales::label_number(accuracy = 1, big.mark = ",")(v)
#Yamanote line
y_hourly   <- readr::read_csv("data/processed/jreast/yamanote_hourly_departures.csv", show_col_types = FALSE)
y_headways <- readr::read_csv("data/processed/jreast/yamanote_headways.csv", show_col_types = FALSE)
y_span     <- readr::read_csv("data/processed/jreast/yamanote_service_span.csv", show_col_types = FALSE)
y_stops    <- readr::read_csv("data/processed/jreast/yamanote_stops.csv", show_col_types = FALSE)
week_file <- "data/processed/jreast/yamanote_weekday_weekend_profile.csv"
y_week <- if (file.exists(week_file)) readr::read_csv(week_file, show_col_types = FALSE) else NULL
ps_file <- "data/jreast/passenger_survey.json"   # <-- change if your file name differs
stopifnot(file.exists(ps_file))
ps <- fromJSON(ps_file)
ps_y <- as_tibble(ps) %>%
filter(map_lgl(`odpt:railway`, ~ "odpt.Railway:JR-East.Yamanote" %in% .x)) %>%
select(
station_id = `owl:sameAs`,
survey = `odpt:passengerSurveyObject`
)
ps_y_long <- ps_y %>%
mutate(survey = map(survey, ~ as_tibble(.x))) %>%
unnest(survey) %>%
transmute(
station_id,
surveyYear = `odpt:surveyYear`,
passengerJourneys = `odpt:passengerJourneys`
)
bmt_hour_profile <- daily_hour_bmt %>%
group_by(day_type, hour) %>%
summarise(
avg_riders = mean(riders, na.rm = TRUE),
p10 = quantile(riders, 0.10, na.rm = TRUE),
p90 = quantile(riders, 0.90, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(day_type, hour)
# Write file
out_file <- "data/mta/bmt_hour_profile.csv"
dir.create(dirname(out_file), recursive = TRUE, showWarnings = FALSE)
readr::write_csv(bmt_hour_profile, out_file)
# Verify
file.exists(out_file)
knitr::opts_chunk$set(echo = FALSE, message = FALSE, warning = FALSE)
library(tidyverse)
library(plotly)
library(scales)
library(jsonlite)
library(stringr)
df <- readr::read_csv("data/mta/bmt_hour_profile.csv", show_col_types = FALSE)
mta_blue   <- "#0039A6"
mta_orange <- "#FF6319"
fmtN <- function(v) scales::label_number(accuracy = 1, big.mark = ",")(v)
#Yamanote line
y_hourly   <- readr::read_csv("data/processed/jreast/yamanote_hourly_departures.csv", show_col_types = FALSE)
y_headways <- readr::read_csv("data/processed/jreast/yamanote_headways.csv", show_col_types = FALSE)
y_span     <- readr::read_csv("data/processed/jreast/yamanote_service_span.csv", show_col_types = FALSE)
y_stops    <- readr::read_csv("data/processed/jreast/yamanote_stops.csv", show_col_types = FALSE)
week_file <- "data/processed/jreast/yamanote_weekday_weekend_profile.csv"
y_week <- if (file.exists(week_file)) readr::read_csv(week_file, show_col_types = FALSE) else NULL
ps_file <- "data/jreast/passenger_survey.json"   # <-- change if your file name differs
stopifnot(file.exists(ps_file))
ps <- fromJSON(ps_file)
ps_y <- as_tibble(ps) %>%
filter(map_lgl(`odpt:railway`, ~ "odpt.Railway:JR-East.Yamanote" %in% .x)) %>%
select(
station_id = `owl:sameAs`,
survey = `odpt:passengerSurveyObject`
)
ps_y_long <- ps_y %>%
mutate(survey = map(survey, ~ as_tibble(.x))) %>%
unnest(survey) %>%
transmute(
station_id,
surveyYear = `odpt:surveyYear`,
passengerJourneys = `odpt:passengerJourneys`
)
# BMT-served complexes hourly profile (make sure you loaded this in setup):
# df <- readr::read_csv("data/mta/bmt_hour_profile.csv", show_col_types = FALSE)
# Two highest weekday peak hours (BMT-served complexes)
peak_hours <- df %>%
filter(day_type == "Weekday") %>%
arrange(desc(avg_riders)) %>%
distinct(hour, .keep_all = TRUE) %>%
slice(1:2) %>%
arrange(hour) %>%
pull(hour)
y_top <- max(df$p90, na.rm = TRUE) * 1.02
p <- ggplot(df, aes(hour, avg_riders, color = day_type, fill = day_type)) +
geom_ribbon(aes(ymin = p10, ymax = p90), alpha = 0.18, color = NA) +
geom_line(linewidth = 1.2) +
geom_point(size = 2.4) +
geom_vline(xintercept = peak_hours, linewidth = 0.9, linetype = "dashed", color = mta_blue) +
geom_text(
data = tibble(hour = peak_hours),
aes(x = hour, y = y_top, label = "Rush hour"),
inherit.aes = FALSE, color = mta_blue, fontface = "bold", vjust = 0, size = 3.6
) +
scale_x_continuous(breaks = 0:23) +
scale_y_continuous(
labels = label_number(scale = 1e-3, suffix = "K"),
expand = expansion(mult = c(0, 0.10))
) +
scale_color_manual(values = c(Weekday = mta_blue, Weekend = mta_orange)) +
scale_fill_manual(values  = c(Weekday = mta_blue, Weekend = mta_orange)) +
labs(
title = "BMT-served complexes â€” Rush Hour 2025 (average riders by hour)",
subtitle = "Approximation: includes all riders entering station complexes served by at least one BMT line",
x = "Hour of day",
y = "Average riders",
color = NULL, fill = NULL
) +
theme_minimal(base_size = 12) +
theme(
panel.grid = element_blank(),
plot.title = element_text(face = "bold"),
axis.line = element_line(color = "gray30", linewidth = 0.6),
axis.ticks = element_line(color = "gray30"),
legend.position = "right"
)
g <- ggplotly(p, tooltip = c("x", "y", "color")) %>%
layout(
legend = list(orientation = "v", x = 1.02, y = 0.5, xanchor = "left", yanchor = "middle"),
margin = list(r = 140),
hovermode = "closest"
)
# 1) Disable default hover everywhere
for (i in seq_along(g$x$data)) {
g$x$data[[i]]$hoverinfo <- "skip"
g$x$data[[i]]$hovertemplate <- NULL
}
# 2) Enable hover only on marker traces for Weekday/Weekend
for (i in seq_along(g$x$data)) {
tr <- g$x$data[[i]]
if (!is.null(tr$mode) && grepl("markers", tr$mode) &&
!is.null(tr$name) && tr$name %in% c("Weekday","Weekend")) {
tr$text <- paste0("Hour of Day: ", tr$x, "<br>Average Riders: ", fmtN(tr$y))
tr$hoverinfo <- "text"
tr$hovertemplate <- "%{text}<extra></extra>"
g$x$data[[i]] <- tr
}
}
# 3) Add invisible hover targets for band edges (p10/p90)
add_band_hover <- function(g, d, which = c("p10","p90"), label) {
ycol <- which[1]
g %>% add_trace(
data = d,
x = ~hour, y = as.formula(paste0("~", ycol)),
type = "scatter", mode = "markers",
marker = list(opacity = 0, size = 12),
inherit = FALSE, showlegend = FALSE,
hovertemplate = ~paste0(
"Hour of Day: ", hour,
"<br>", label, ": ", fmtN(.data[[ycol]]),
"<extra></extra>"
)
)
}
for (dt in c("Weekday","Weekend")) {
dsub <- df %>% filter(day_type == dt) %>% arrange(hour)
g <- add_band_hover(g, dsub, which = "p10", label = "Low Band (10th%)")
g <- add_band_hover(g, dsub, which = "p90", label = "High Band (90th%)")
}
# 4) Legend whitelist
shown <- character(0)
for (i in seq_along(g$x$data)) {
nm <- trimws(ifelse(is.null(g$x$data[[i]]$name), "", g$x$data[[i]]$name))
g$x$data[[i]]$showlegend <- FALSE
if (nm %in% c("Weekday","Weekend") && !(nm %in% shown)) {
g$x$data[[i]]$showlegend <- TRUE
shown <- c(shown, nm)
}
}
g %>% config(displayModeBar = FALSE)
# Force rush hour markers to 7 and 17
peak_hours <- c(8, 17)
y_top <- max(df$p90, na.rm = TRUE) * 1.02
p <- ggplot(df, aes(hour, avg_riders, color = day_type, fill = day_type)) +
