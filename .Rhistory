# ============================================================
# Yamanote headway plot — uses FIXED headway_profile.csv
# Run fix_headways.R first to regenerate the source data
# ============================================================
library(tidyverse)
library(plotly)
GREEN    <- "#0CA10E"
YELLOW   <- "#FCCC0A"
hp <- read_csv("data/processed/jreast/yamanote_headway_profile.csv",
show_col_types = FALSE) %>%
mutate(day_type = factor(day_type, levels = c("Weekday", "Weekend")))
ref <- hp$ref_stop[1]
wk  <- hp %>% filter(day_type == "Weekday")
we  <- hp %>% filter(day_type == "Weekend")
wk_peak <- wk %>% filter(hour %in% 8:9) %>% pull(median_hw_min) %>% median(na.rm = TRUE)
y_max   <- max(hp$q75, na.rm = TRUE) * 1.2
p <- ggplot(hp, aes(
x = hour, y = median_hw_min,
color = day_type, group = day_type,
text = paste0(
if_else(day_type == "Weekend", "On weekends", "On weekdays"),
", at hour ", hour,
", trains arrive every ", round(median_hw_min, 1), " minutes on average."
)
)) +
geom_ribbon(data = wk, aes(x = hour, ymin = q25, ymax = q75),
inherit.aes = FALSE, fill = GREEN,  alpha = 0.15) +
geom_ribbon(data = we, aes(x = hour, ymin = q25, ymax = q75),
inherit.aes = FALSE, fill = YELLOW, alpha = 0.15) +
geom_line(linewidth = 1.4) +
geom_point(size = 2.8) +
scale_color_manual(values = c(Weekday = GREEN, Weekend = YELLOW)) +
geom_vline(xintercept = c(8, 17), linetype = "dashed",
linewidth = 0.9, color = "gray50") +
annotate("text", x = 8,  y = y_max, label = "AM rush",
hjust = 0.5, size = 3.2, color = "gray40") +
annotate("text", x = 17, y = y_max, label = "PM rush",
hjust = 0.5, size = 3.2, color = "gray40") +
# The story: how flat the line is
annotate("segment", x = 8, xend = 17, y = wk_peak, yend = wk_peak,
color = GREEN, linewidth = 0.7, linetype = "dotted") +
annotate("label", x = 12.5, y = wk_peak + 0.6,
label = paste0("~", round(wk_peak, 1), " min all peak hours"),
size = 3.1, color = GREEN, fill = "white", label.size = 0,
fontface = "bold") +
scale_x_continuous(breaks = 5:23) +
scale_y_continuous(
breaks = seq(0, 12, 2),
limits = c(0, y_max + 1),
expand = expansion(mult = c(0, 0.05))
) +
labs(
title = "Yamanote Line — Minutes between trains by hour",
subtitle = paste0("Lower = more frequent  •  Ref. station: ", ref,
"  •  Shaded = IQR  •  Source: JR East GTFS"),
x = "Hour of day", y = "Minutes between trains", color = NULL
) +
theme_minimal(base_size = 12) +
theme(
panel.grid.major = element_blank(),
panel.grid.minor = element_blank(),
axis.line  = element_line(color = "gray30", linewidth = 0.6),
axis.ticks = element_line(color = "gray30"),
plot.title = element_text(face = "bold"),
plot.subtitle = element_text(color = "gray40", size = 10),
legend.position = "top"
)
ggplotly(p, tooltip = "text") %>%
layout(
hovermode = "closest",
xaxis = list(showgrid = FALSE, fixedrange = TRUE, zeroline = FALSE),
yaxis = list(showgrid = FALSE, fixedrange = TRUE, zeroline = FALSE)
) %>%
config(displayModeBar = FALSE, scrollZoom = FALSE, doubleClick = FALSE)
mta_blue   <- "#0039A6"
mta_orange <- "#FF6319"
overall <- readr::read_csv("data/mta/mta_otp_bmt_overall.csv", show_col_types = FALSE) %>%
mutate(
day_type = factor(day_type, levels = c("Weekday","Weekend")),
month = as.Date(month),
day_word = if_else(day_type == "Weekend", "Weekends", "Weekdays"),
month_lbl = format(month, "%B %Y"),
hover_text = paste0(day_word, " in ", month_lbl, " showed ",
percent(otp, accuracy = 0.1),
" on-time performance.")
)
hi <- overall %>%
group_by(day_type) %>%
slice_max(otp, n = 1, with_ties = FALSE) %>%
bind_rows(
overall %>% group_by(day_type) %>% slice_min(otp, n = 1, with_ties = FALSE)
) %>%
ungroup()
x_pad_days <- 25
x_min <- min(overall$month) - x_pad_days
x_max <- max(overall$month) + x_pad_days
p <- ggplot(overall, aes(month, otp, color = day_type, group = day_type, text = hover_text)) +
geom_line(linewidth = 1.35) +
geom_point(size = 2.8) +
geom_point(
data = hi,
aes(month, otp, group = day_type),
inherit.aes = FALSE,
size = 4.6,
shape = 21,
stroke = 1.6,
fill = "white",
color = "gray20"
) +
scale_color_manual(values = c(Weekday = mta_blue, Weekend = mta_orange)) +
scale_x_date(limits = c(x_min, x_max)) +
scale_y_continuous(
labels = percent_format(accuracy = 1),
expand = expansion(mult = c(0.06, 0.12))
) +
labs(
title = "BMT On-Time Performance — Weekday vs Weekend (2025)",
subtitle = "Trips-weighted terminal on-time performance (weekday vs weekend)",
x = NULL,
y = "On-time performance",
color = NULL
) +
theme_minimal(base_size = 12) +
theme(
panel.grid.major = element_blank(),
panel.grid.minor = element_blank(),
axis.line = element_line(color = "gray30", linewidth = 0.6),
axis.ticks = element_line(color = "gray30"),
plot.title = element_text(face = "bold"),
legend.position = "top"
)
ggplotly(p, tooltip = "text") %>%
layout(
legend = list(orientation = "v", x = 1.02, y = 0.5, xanchor = "left", yanchor = "middle"),
margin = list(r = 140),
hovermode = "closest",
xaxis = list(showgrid = FALSE, fixedrange = TRUE, zeroline = FALSE),
yaxis = list(showgrid = FALSE, fixedrange = TRUE, zeroline = FALSE)
) %>%
config(
displayModeBar = FALSE,
scrollZoom = FALSE,
doubleClick = FALSE
)
readLines("about.qmd")
