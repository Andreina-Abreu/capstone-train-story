)
ggplotly(p3, tooltip = "text") %>%
layout(hovermode = "closest",
legend = list(title = list(text = ""))) %>%
config(displayModeBar = FALSE)
mta_blue   <- "#0039A6"
mta_orange <- "#FF6319"
# Rush-hour markers (you can change these)
rush_lines <- c(8, 17)
wk <- readr::read_csv("data/mta/bmt_trips_by_hour_weekday.csv", show_col_types = FALSE) %>%
mutate(day_type = "Weekday")
we <- readr::read_csv("data/mta/bmt_trips_by_hour_weekend.csv", show_col_types = FALSE) %>%
mutate(day_type = "Weekend")
tot <- bind_rows(wk, we) %>%
group_by(day_type, hour_service) %>%
summarize(trips = sum(trips, na.rm = TRUE), .groups = "drop") %>%
filter(hour_service <= 23) %>%
mutate(
day_phrase = if_else(day_type == "Weekend", "On weekends", "On weekdays"),
se = sqrt(pmax(trips, 1)),
lo = pmax(trips - 1.2 * se, 0),
hi = trips + 1.2 * se,
hover_text = paste0(
day_phrase, ", in hour ", hour_service,
", there are ", trips, " trips scheduled."
)
)
wk_df <- tot %>% filter(day_type == "Weekday")
we_df <- tot %>% filter(day_type == "Weekend")
y_top <- max(tot$hi, na.rm = TRUE) * 1.02
peaks <- tot %>%
group_by(day_type) %>%
slice_max(trips, n = 1, with_ties = FALSE) %>%
ungroup()
p <- ggplot(tot, aes(hour_service, trips, color = day_type, group = day_type, text = hover_text)) +
# shaded bands (fixed fill so legend stays clean)
geom_ribbon(
data = wk_df,
aes(x = hour_service, ymin = lo, ymax = hi),
inherit.aes = FALSE,
fill = mta_blue, alpha = 0.15
) +
geom_ribbon(
data = we_df,
aes(x = hour_service, ymin = lo, ymax = hi),
inherit.aes = FALSE,
fill = mta_orange, alpha = 0.15
) +
geom_line(linewidth = 1.4) +
geom_point(size = 2.4) +
geom_point(
data = peaks,
aes(hour_service, trips, group = day_type),
inherit.aes = FALSE,
size = 4.6,
shape = 21,
stroke = 1.6,
fill = "white",
color = "gray20"
) +
geom_vline(xintercept = rush_lines, linetype = "dashed", linewidth = 0.9, alpha = 0.9) +
annotate(
"text",
x = rush_lines, y = y_top,
label = "Rush hour",
vjust = 0, size = 3.5, fontface = "bold", color = mta_blue
) +
scale_color_manual(values = c(Weekday = mta_blue, Weekend = mta_orange)) +
scale_x_continuous(breaks = 0:23, limits = c(0, 23)) +
labs(
title = "Stop 3 — Frequency (BMT total service by hour)",
subtitle = "Lines show scheduled trips/hour. Shaded band is a visual range (schedule-based).",
x = "Service hour",
y = "Total scheduled trip starts",
color = NULL
) +
theme_minimal(base_size = 12) +
theme(
panel.grid.major = element_blank(),
panel.grid.minor = element_blank(),
axis.line = element_line(color = "gray30", linewidth = 0.6),
axis.ticks = element_line(color = "gray30"),
plot.title = element_text(face = "bold"),
legend.position = "top"
)
ggplotly(p, tooltip = "text") %>%
layout(
hovermode = "closest",
xaxis = list(showgrid = FALSE, fixedrange = TRUE, zeroline = FALSE),
yaxis = list(showgrid = FALSE, fixedrange = TRUE, zeroline = FALSE)
) %>%
config(displayModeBar = FALSE, scrollZoom = FALSE, doubleClick = FALSE)
